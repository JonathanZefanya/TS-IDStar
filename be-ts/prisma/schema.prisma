generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int         @id @default(autoincrement())
  name          String      @db.VarChar(150)
  roleSystem    String      @map("role_system") @db.VarChar(20) @default("user")
  roleJob       String      @map("role_job") @db.VarChar(100)
  department    String      @db.VarChar(100)
  location      String      @db.VarChar(150)
  project       String      @db.VarChar(150)
  teamLeadName  String      @map("team_lead_name") @db.VarChar(150)
  deptHeadName  String      @map("dept_head_name") @db.VarChar(150)
  clientLogoDataUrl String? @map("client_logo_data_url") @db.MediumText
  username      String      @unique @db.VarChar(100)
  password      String      @db.VarChar(255)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  timesheets    Timesheet[]

  @@map("users")
}

model Timesheet {
  id        Int              @id @default(autoincrement())
  userId    Int              @map("user_id")
  period    String           @db.VarChar(7)
  status    String           @db.VarChar(20) @default("draft")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries   TimesheetEntry[]

  @@unique([userId, period])
  @@map("timesheets")
}

model TimesheetEntry {
  id          Int        @id @default(autoincrement())
  timesheetId Int        @map("timesheet_id")
  date        DateTime   @db.Date
  dayName     String     @map("day_name") @db.VarChar(20)
  startTime   String     @map("start_time") @db.VarChar(5)
  lunchBreak  String     @map("lunch_break") @db.VarChar(13)
  endTime     String     @map("end_time") @db.VarChar(5)
  totalHours  Float      @map("total_hours")
  activity    String     @db.Text
  timesheet   Timesheet  @relation(fields: [timesheetId], references: [id], onDelete: Cascade)

  @@unique([timesheetId, date])
  @@map("timesheet_entries")
}

model Holiday {
  id        Int      @id @default(autoincrement())
  date      DateTime @unique @db.Date
  name      String   @db.VarChar(150)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("holidays")
}
